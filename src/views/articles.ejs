<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Express & Passport</title>
    
    <link rel="icon" type="image/png" href="/favicon-<%= currentTheme %>.png">
    
    <link rel="stylesheet" href="/css/style.css"> 
</head>
<body class="<%= currentTheme %>-theme">

    <header>

        <% if (user) { %>
            <p>Вітаємо, <strong><%= user.name %></strong>! | <a href="/logout">Вийти</a></p>
        <% } else { %>
            <form action="/login" method="POST">
                <input type="text" name="username" placeholder="Ваше ім'я" required>
                <button type="submit">Увійти (JWT)</button>
            </form>
        <% } %>

        <hr>

     
        <p>Поточна тема: <%= currentTheme %></p>
        <a href="/change-theme/light">☀️ Світла</a> | 
        <a href="/change-theme/dark">🌙 Темна</a>
    </header>

    <main>
        <h1>Головна сторінка</h1>
    </main>

</body>
</html>
