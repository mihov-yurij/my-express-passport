<!DOCTYPE html>
<html>
<head>
    <title>Cookies & JWT Test</title>
    <!-- Задача №2: Динамический Favicon -->
    <link rel="icon" type="image/png" href="/favicon-<%= currentTheme %>.png">
</head>
<body class="<%= currentTheme %>">
    <h1>Тема: <%= currentTheme %></h1>
    
    <!-- Задача №4: Проверка JWT -->
    <% if (user) { %>
        <p>Вы вошли как: <strong><%= user.name %></strong> | <a href="/logout">Выйти</a></p>
    <% } else { %>
        <form action="/login" method="POST">
            <input type="text" name="username" placeholder="Имя" required>
            <button type="submit">Войти</button>
        </form>
    <% } %>

    <hr>
    <!-- Задача №3: Работа с Cookies -->
    <a href="/change-theme/light">☀️ Светлая</a> | 
    <a href="/change-theme/dark">🌙 Темная</a>
</body>
</html>
